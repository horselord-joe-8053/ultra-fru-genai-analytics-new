# API Deployment. Rendered for AWS (eks) or GCP (gke) via kube_apply.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: fru-api
  namespace: fru-kube
spec:
  replicas: 2
  selector:
    matchLabels:
      app: fru-api
  template:
    metadata:
      labels:
        app: fru-api
    spec:
      containers:
      - name: api
        image: {{ APP_IMAGE }}
        ports:
        - containerPort: 5001
        livenessProbe:
          httpGet:
            path: /health
            port: 5001
          initialDelaySeconds: 60
          periodSeconds: 15
          timeoutSeconds: 10
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 5001
          initialDelaySeconds: 30
          periodSeconds: 10
          timeoutSeconds: 10
          failureThreshold: 3
        env:
        - name: PGHOST
          value: "{{ PGHOST }}"
        - name: PGPORT
          value: "{{ PGPORT }}"
        - name: PGUSER
          value: "{{ PGUSER }}"
        - name: PGDATABASE
          value: "{{ PGDATABASE }}"
        - name: PGPASSWORD
          valueFrom:
            secretKeyRef:
              name: db-credentials
              key: PGPASSWORD
        - name: OPENAI_API_KEY
          valueFrom:
            secretKeyRef:
              name: app-credentials
              key: OPENAI_API_KEY
{% if cloud_provider == "aws" %}
        - name: AWS_ACCESS_KEY_ID
          valueFrom:
            secretKeyRef:
              name: aws-credentials
              key: AWS_ACCESS_KEY_ID
        - name: AWS_SECRET_ACCESS_KEY
          valueFrom:
            secretKeyRef:
              name: aws-credentials
              key: AWS_SECRET_ACCESS_KEY
{% elif cloud_provider == "gcp" %}
        - name: CLAUDE_API_KEY
          valueFrom:
            secretKeyRef:
              name: app-credentials
              key: CLAUDE_API_KEY
              optional: true
        - name: GOOGLE_AI_API_KEY
          valueFrom:
            secretKeyRef:
              name: app-credentials
              key: GOOGLE_AI_API_KEY
              optional: true
{% else %}
        {# local: OPENAI + optional CLAUDE for agent #}
        - name: CLAUDE_API_KEY
          valueFrom:
            secretKeyRef:
              name: app-credentials
              key: CLAUDE_API_KEY
              optional: true
{% endif %}
        - name: LOG_LEVEL
          value: "INFO"
        - name: ALLOWED_ORIGINS
          value: "{{ ALLOWED_ORIGINS }}"
        - name: OPENAI_EMBED_MODEL
          value: "{{ OPENAI_EMBED_MODEL }}"
        - name: USE_AGENT_QUERY
          value: "true"
        - name: DEPLOY_SCOPE
          value: "{{ DEPLOY_SCOPE }}"
        - name: CLOUD_PROVIDER
          value: "{{ CLOUD_PROVIDER }}"
        - name: CLOUD_REGION
          value: "{{ CLOUD_REGION }}"
        - name: CONTAINER_IMAGE
          value: "{{ APP_IMAGE }}"
        - name: CONTAINER_IMAGE_TAGS
          value: "{{ CONTAINER_IMAGE_TAGS }}"
        - name: CONTAINER_TYPE
          value: "{{ CONTAINER_TYPE }}"
        - name: DELTA_TABLE_PATH
          value: "{{ DELTA_TABLE_PATH }}"
        - name: DELTA_LAKE_PACKAGE
          value: "{{ DELTA_LAKE_PACKAGE }}"
        - name: SPARK_HOME
          value: "{{ SPARK_HOME }}"
{% if cloud_provider == "aws" %}
        - name: AWS_BEDROCK_INFERENCE_PROFILE_ID
          value: "{{ AWS_BEDROCK_INFERENCE_PROFILE_ID }}"
        - name: AWS_BEDROCK_MODEL_ID
          value: "{{ AWS_BEDROCK_MODEL_ID }}"
{% elif cloud_provider == "gcp" %}
        - name: GCP_LLM_PROVIDER
          value: "{{ GCP_LLM_PROVIDER }}"
        - name: LLM_PROVIDER
          value: "{{ GCP_LLM_PROVIDER }}"
        - name: CLAUDE_MODEL
          value: "{{ CLAUDE_MODEL }}"
        - name: GOOGLE_MODEL
          value: "{{ GOOGLE_MODEL }}"
{% else %}
        {# local: use CLAUDE_API_KEY if set, else OPENAI. Models still come from env/SoT. #}
        - name: GCP_LLM_PROVIDER
          value: "{{ GCP_LLM_PROVIDER | default('claude') }}"
        - name: LLM_PROVIDER
          value: "{{ GCP_LLM_PROVIDER | default('claude') }}"
        - name: CLAUDE_MODEL
          value: "{{ CLAUDE_MODEL }}"
        - name: GOOGLE_MODEL
          value: "{{ GOOGLE_MODEL }}"
{% endif %}
        - name: ENABLE_ANALYTICS_SCHEDULER
          value: "{{ ENABLE_ANALYTICS_SCHEDULER }}"
        - name: ANALYTICS_SCHEDULER_INTERVAL_SECONDS
          value: "{{ ANALYTICS_SCHEDULER_INTERVAL_SECONDS }}"
