# One-off Spark analytics bootstrap. Populates batch_analytics.
apiVersion: batch/v1
kind: Job
metadata:
  name: fru-analytics-bootstrap-kube
  namespace: fru-kube
spec:
  template:
    spec:
      containers:
      - name: spark
        image: {{ SPARK_IMAGE }}
{% if cloud_provider == "aws" %}
        command: ["/opt/spark/bin/spark-submit", "--packages", "{{ DELTA_LAKE_PACKAGE }},{{ DELTA_STORAGE_PACKAGE }},{{ HADOOP_PACKAGE }}", "/opt/fru/jobs/run_analytics.py"]
{% elif cloud_provider == "gcp" %}
        {# GCP: Use pre-bundled JARs from Spark image (--jars) instead of --packages.
           Reason: GKE pods may lack egress to Maven; Delta/GCS JARs are baked into the image. #}
        command: ["/opt/spark/bin/spark-submit", "--jars", "/opt/fru/jars/gcs-connector-hadoop3-2.2.7-shaded.jar,/opt/fru/jars/delta-spark_2.13-4.0.0.jar,/opt/fru/jars/delta-storage-4.0.0.jar", "/opt/fru/jobs/run_analytics.py"]
{% else %}
        {# local: file:// delta, no cloud storage #}
        command: ["/opt/spark/bin/spark-submit", "--conf", "spark.driver.extraJavaOptions=-Duser.home=/tmp", "--conf", "spark.executor.extraJavaOptions=-Duser.home=/tmp", "--packages", "{{ DELTA_LAKE_PACKAGE }},{{ DELTA_STORAGE_PACKAGE }}", "/opt/fru/jobs/run_analytics.py"]
{% endif %}
        env:
        - name: SPARK_EXTRA_CONF
          value: "spark.fru.delta_root={{ DELTA_ROOT }}"
        - name: DELTA_TABLE_PATH
          value: "{{ DELTA_TABLE_PATH }}"
        - name: PGHOST
          value: "{{ PGHOST }}"
        - name: PGPORT
          value: "{{ PGPORT }}"
        - name: PGDATABASE
          value: "{{ PGDATABASE }}"
        - name: PGUSER
          value: "{{ PGUSER }}"
        - name: PGPASSWORD
          valueFrom:
            secretKeyRef:
              name: db-credentials
              key: PGPASSWORD
{% if cloud_provider == "aws" %}
        - name: AWS_ACCESS_KEY_ID
          value: "{{ AWS_ACCESS_KEY_ID }}"
        - name: AWS_SECRET_ACCESS_KEY
          value: "{{ AWS_SECRET_ACCESS_KEY }}"
{% elif cloud_provider == "gcp" %}
        - name: CLOUD_PROVIDER
          value: "gcp"
{% else %}
        - name: CLOUD_PROVIDER
          value: "local"
{% endif %}
        - name: CLOUD_REGION
          value: "{{ CLOUD_REGION }}"
        - name: DEPLOY_SCOPE
          value: "kube"
{% if cloud_provider == "local" %}
        volumeMounts:
        - name: delta
          mountPath: /tmp/delta
{% endif %}
      restartPolicy: Never
{% if cloud_provider == "local" %}
      volumes:
      - name: delta
        hostPath:
          path: /tmp/fru-delta
          type: DirectoryOrCreate
{% endif %}
  backoffLimit: 4
