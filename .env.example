# =============================================================================
# COMMON (local + all providers)
# =============================================================================
# Database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<redacted>
PGDATABASE=fru_db

# OpenAI
OPENAI_API_KEY=<redacted>
OPENAI_EMBED_MODEL=text-embedding-3-small

# Claude (local dev / fallback when not using cloud LLM)
CLAUDE_API_KEY=<redacted>

# Application
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
USE_AGENT_QUERY=true

# Local development
LOCAL_SERVER_PORT=5001
IMAGE_PREFIX=fru-api-img-default-prefix

# Spark + Delta Lake (batch analytics)
ENABLE_ANALYTICS_SCHEDULER=true
ANALYTICS_SCHEDULER_INTERVAL_SECONDS=180
DELTA_LAKE_PACKAGE=io.delta:delta-spark_2.13:4.0.0
DELTA_TABLE_PATH=data/delta/fru_sales
SPARK_VERSION=4.0.1
HADOOP_VERSION=3
DELTA_LAKE_VERSION=4.0.0
SCALA_VERSION=2.13

# Batch Analytics (frontend + API)
VITE_FRONTEND_POLL_FREQUENCY_IN_SEC=60
NUM_FOR_BATCH_ANALYTICS_TOP_SPARK_COMPUTE=20
NUM_FOR_BATCH_ANALYTICS_TOP_QUERY=4
VITE_FRONTEND_EXEC_LOG_PANEL_WIDTH_PERCENT=0.4
VITE_FRONTEND_BATCH_ANALYTIC_PANEL_WIDTH_PERCENT=0.1

# =============================================================================
# AWS
# =============================================================================
# Credentials (used by setup-aws-profiles.sh to populate ~/.aws/credentials)
AWS_ADMIN_ACCESS_KEY_ID=<redacted>
AWS_ADMIN_SECRET_ACCESS_KEY=<redacted>
AWS_BEDROCK_ACCESS_KEY_ID=<redacted>
AWS_BEDROCK_SECRET_ACCESS_KEY=<redacted>

# Profile & region
AWS_PROFILE=admin
CLOUD_REGION=us-east-1
# Prefer profile over .env keys (avoids AuthFailure when .env keys are rotated but profile is current)
# FRU_AWS_USE_PROFILE=true
# Region: use CLOUD_REGION only (tools pass it explicitly to boto3/AWS CLI)
# Frontend S3 bucket is created in this region; bucket name includes region for multi-region deployments.


# Bedrock (inference)
AWS_BEDROCK_INFERENCE_PROFILE_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# Terraform state (S3 bucket; must be globally unique)
TF_STATE_BUCKET=fru-terraform-state-744139897900
# Per-region overrides: TF_STATE_BUCKET_us_east_2, TF_STATE_LOCK_TABLE_us_east_2 (region: us-east-2 -> us_east_2)
# TF_STATE_BUCKET_us_east_2=fru-terraform-state-us-east-2
# TF_STATE_LOCK_TABLE_us_east_2=fru-dev-lock-us-east-2
# Bucket region is resolved dynamically via AWS API. Override to skip API call:
# TF_STATE_BUCKET_REGION=us-east-1

# Container image (set automatically for AWS; ECR URI + tag)
# CONTAINER_IMAGE=<account-id>.dkr.ecr.<region>.amazonaws.com/fru-api:<tag>

# Docker platform for remote/ECR images (build and run on host)
# Set to linux/amd64 on Apple Silicon (ARM64) so ECR image runs; unset = default linux/amd64.
DOCKER_RUN_REMOTE_PLATFORM=linux/amd64

# Timeout (seconds) for quick Docker commands (docker login, etc). 0 = no timeout. Default 180.
# DOCKER_BASIC_CMD_TIMEOUT=180

# EKS / Kubernetes
BACKEND_KUBE_REPLICA_COUNT=2

# Verification (verify_all_deploy.py: heartbeat + timeout, aligned with legacy)
VERIFY_HEARTBEAT_INTERVAL_SEC=30
VERIFY_TIMEOUT_SEC=300
# Per-request timeout for QueryStream: LLM streaming via Bedrock can take 60–120+ seconds. Default 180.
# VERIFY_QUERY_STREAM_TIMEOUT_PER_REQUEST_SEC=180

# Teardown
# Heartbeat interval for tofu init/destroy (default 10s; shorter than deploy so feedback appears sooner)
TEARDOWN_HEARTBEAT_INTERVAL_SEC=10
# CloudFront OAC retry when destroy fails with OriginAccessControlInUse
# CloudFront distribution deletion can take ~15 min; increase if retry still fails
TEARDOWN_OAC_WAIT_SEC=900
# CloudFront pre-destroy (disable + delete via AWS API before tofu destroy)
CLOUDFRONT_PRE_DESTROY_TIMEOUT_SEC=1800
CLOUDFRONT_PRE_DESTROY_POLL_INTERVAL_SEC=30

# Auth error retry (SignatureDoesNotMatch, AuthFailure): sync clock via NTP and retry
AUTH_REFRESH_FAILURE_RETRY_WAIT_TIME=30
MAX_AUTH_REFRESH_FAILURE_RETRY=3

# =============================================================================
# GCP (max access – equivalent to AWS admin profile + keys)
# =============================================================================
# Infra: Create Service Account in GCP Console → APIs & Services → Credentials →
# Manage service accounts → Create → Assign Owner/Editor → Create JSON key.
# LLM: Get API key from ai.google.dev (Google AI Studio) — simpler than Vertex AI.
# See docs/REFACTOR_PLAN_GCP_READINESS.md Section 1.
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# CLOUD_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GOOGLE_AI_API_KEY=your-api-key-from-ai-google-dev

# =============================================================================
# ORACLE CLOUD (placeholder – set when using Oracle)
# =============================================================================
# OCI_CONFIG_FILE=
# OCI_REGION=

# =============================================================================
# AZURE (placeholder – set when using Azure)
# =============================================================================
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
