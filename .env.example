# =============================================================================
# COMMON (local + all providers)
# =============================================================================
# Project prefix (PROJ_PREFIX preferred; FRU_PREFIX fallback)
PROJ_PREFIX=fru

# Database (local + cloud)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<redacted>
PGDATABASE=fru_db

# OpenAI
OPENAI_API_KEY=<redacted>
OPENAI_EMBED_MODEL=text-embedding-3-small

# Claude (local dev / fallback when not using cloud LLM)
CLAUDE_API_KEY=<redacted>

# Application
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
USE_AGENT_QUERY=true

# /version endpoint (optional – set by Terraform/kube_apply in deployed envs; for local dev only)
# DEPLOY_SCOPE=nonkube
# CLOUD_PROVIDER=aws
# CLOUD_REGION=us-east-1

# Local development
# Path to local deploy config (ports per scope); relative to project root
LOCAL_DEPLOY_CONFIG=config/local/local_deploy_config.yaml
LOCAL_SERVER_PORT=5001
IMAGE_PREFIX=fru-api-img-default-prefix

# Spark + Delta Lake (batch analytics)
ENABLE_ANALYTICS_SCHEDULER=true
# Required. Single source of truth for all flows (local, kube, nonkube). No default; fail-fast if missing.
ANALYTICS_SCHEDULER_INTERVAL_SECONDS=180
DELTA_LAKE_PACKAGE=io.delta:delta-spark_2.13:4.0.0
DELTA_TABLE_PATH=data/delta/fru_sales
SPARK_VERSION=4.0.1
HADOOP_VERSION=3
DELTA_LAKE_VERSION=4.0.0
SCALA_VERSION=2.13

# Batch Analytics (frontend + API)
VITE_FRONTEND_POLL_FREQUENCY_IN_SEC=60
NUM_FOR_BATCH_ANALYTICS_TOP_SPARK_COMPUTE=20
NUM_FOR_BATCH_ANALYTICS_TOP_QUERY=4
VITE_FRONTEND_EXEC_LOG_PANEL_WIDTH_PERCENT=0.4
VITE_FRONTEND_BATCH_ANALYTIC_PANEL_WIDTH_PERCENT=0.1

# Terraform state (shared: AWS S3 + GCP GCS)
TF_STATE_BUCKET_COMPONENT=tf-state
TF_LOCK_TABLE_COMPONENT=tf-locks-tbl

# Shared resource names (AWS + GCP)
K8S_NAMESPACE=fru-kube

# =============================================================================
# AWS
# =============================================================================
# Credentials (used by setup-aws-profiles.sh to populate ~/.aws/credentials)
AWS_ADMIN_ACCESS_KEY_ID=<redacted>
AWS_ADMIN_SECRET_ACCESS_KEY=<redacted>
AWS_BEDROCK_ACCESS_KEY_ID=<redacted>
AWS_BEDROCK_SECRET_ACCESS_KEY=<redacted>

# Profile & region
AWS_PROFILE=admin
CLOUD_REGION=us-east-1
# FRU_AWS_USE_PROFILE=true
# DEFAULT_SCOPE=nonkube

# Bedrock (inference)
AWS_BEDROCK_INFERENCE_PROFILE_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# OpenTofu / Terraform binary
FRU_TF_BIN=tofu

# VPC
VPC_CIDR=10.0.0.0/16

# AWS Resource Names (PROJ_PREFIX + *_COMPONENT; see docs/STEP_LARGE_REFACTOR_RENAMING.md)
# TODO: optimize to use a single artifact repo for multiple images (app + spark)
S3_DELTA_COMPONENT=delta-internal
S3_ARTIFACT_COMPONENT=artifacts-internal
ECR_APP_COMPONENT=api-img-aws
ECR_SPARK_COMPONENT=spark-img-aws
EKS_CLUSTER_COMPONENT=eks
ECS_CLUSTER_COMPONENT=ecs
ALB_COMPONENT=alb
CLOUDWATCH_LOG_GROUP_SPARK=cloud-log-group-spark
CLOUDWATCH_LOG_GROUP_ECS_API=ecs-api

# Docker (build/push for AWS ECR)
DOCKER_RUN_REMOTE_PLATFORM=linux/amd64
# DOCKER_BASIC_CMD_TIMEOUT=180

# EKS / Kubernetes
BACKEND_KUBE_REPLICA_COUNT=2
# Poll for NLB hostname to be generated by AWS Load Balancer Controller (for CloudFront API origin).
# On first deploy, NLB creation is async and can take 5–10+ min. See docs/war_stories/WAR_STORIES_AWS.md §43.
# KUBE_LB_POLL_MAX_ATTEMPTS=60
# KUBE_LB_POLL_INTERVAL_SEC=20

# Logging (bootstrap job verification)
# LOGGING_TASK_HEARBEAT_INTERVAL=30
# LOGGING_TASK_DEFAULT_TIMEOUT=3600

# Verification & teardown
VERIFY_HEARTBEAT_INTERVAL_SEC=30
VERIFY_TIMEOUT_SEC=300
TEARDOWN_OAC_WAIT_SEC=900
CLOUDFRONT_PRE_DESTROY_TIMEOUT_SEC=1800
CLOUDFRONT_PRE_DESTROY_POLL_INTERVAL_SEC=30

# Auth error retry
AUTH_REFRESH_FAILURE_RETRY_WAIT_TIME=30
MAX_AUTH_REFRESH_FAILURE_RETRY=3

# =============================================================================
# GCP
# =============================================================================
# Project & region
# GCP_PROJECT_ID=your-gcp-project-id
# CLOUD_REGION=us-central1

# Credentials
# Copy .cred_config/gcp_service_key.example.json to .cred_config/gcp_service_key.json
# and fill in real values. Then set:
# GOOGLE_APPLICATION_CREDENTIALS=.cred_config/gcp_service_key.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={...}

# GCP Resource Names (PROJ_PREFIX + *_COMPONENT; same convention as AWS)
# TODO: optimize to use a single artifact repo for multiple images (app + spark)
GCS_DELTA_COMPONENT=delta-internal
ARTIFACT_REGISTRY_APP_COMPONENT=api-img-gcp
ARTIFACT_REGISTRY_SPARK_COMPONENT=spark-img-gcp
GKE_CLUSTER_COMPONENT=gke
CLOUD_RUN_SERVICE_COMPONENT=api-nonkube
SPARK_JOB_COMPONENT=spark
CLOUD_LOGGING_LOG_SPARK_COMPONENT=spark

# LLM (Google AI Studio)
# GOOGLE_AI_API_KEY=your-api-key-from-ai-google-dev
# GEMINI_MODEL=gemini-2.5-flash

# GCP LLM provider: claude or google (avoids Gemini free-tier RPD limit)
# GCP_LLM_PROVIDER=claude
# CLAUDE_API_KEY=your-anthropic-api-key

# Model overrides (optional; backend has defaults)
# GOOGLE_MODEL=gemini-2.5-flash
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# =============================================================================
# ORACLE CLOUD (placeholder – set when using Oracle)
# =============================================================================
# OCI_CONFIG_FILE=
# OCI_REGION=

# =============================================================================
# AZURE (placeholder – set when using Azure)
# =============================================================================
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
